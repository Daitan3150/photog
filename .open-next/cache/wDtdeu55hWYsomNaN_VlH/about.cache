\"property\":\"og:url\",\"content\":\"https://next-portfolio-eosin-eight.vercel.app\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:site_name\",\"content\":\"DAITAN Portfolio\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:locale\",\"content\":\"ja_JP\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image:alt\",\"content\":\"DAITAN Portfolio\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:type\",\"content\":\"image/png\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image\",\"content\":\"https://next-portfolio-eosin-eight.vercel.app/opengraph-image?72eff46bf5545edb\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:creator\",\"content\":\"@daitan_photo\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:title\",\"content\":\"DAITAN | Photographer\"}],[\"$\",\"meta\",\"17\",{\"name\":\"twitter:description\",\"content\":\"Capture the moment. Portfolio of Daitan.\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:image:alt\",\"content\":\"DAITAN Portfolio\"}],[\"$\",\"meta\",\"19\",{\"name\":\"twitter:image:type\",\"content\":\"image/png\"}],[\"$\",\"meta\",\"20\",{\"name\":\"twitter:image\",\"content\":\"https://next-portfolio-eosin-eight.vercel.app/opengraph-image?72eff46bf5545edb\"}],[\"$\",\"meta\",\"21\",{\"name\":\"twitter:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"22\",{\"name\":\"twitter:image:height\",\"content\":\"630\"}],[\"$\",\"link\",\"23\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.0b3bf435.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"$L14\",\"24\",{}]]\n15:I[12833,[\"/_next/static/chunks/d9fddd7e35bd589e.js\",\"/_next/static/chunks/152be74abaeef57d.js\",\"/_next/static/chunks/8d9ce281e2699520.js\",\"/_next/static/chunks/713069435030f2db.js\",\"/_next/static/chunks/9a952a831bca74b0.js\"],\"default\"]\nb:[\"$\",\"$L15\",null,{\"profile\":{\"role\":\"\",\"name\":\"\",\"bio\":\"北海道を拠点に、人と世界のあいだに生まれる“かすかな気配”を写し取るフォトグラファー。\\n\\n被写体がキャラクターであれ、日常の断片であれ、\\nそこに流れる温度・呼吸・沈黙を丁寧に拾い上げ、\\n写真という形に変換することを探求している。\\n\\nDaitanの写真には、派手な演出や誇張はほとんどない。\\n光の柔らかさ、色の静けさ、余白の深さ。\\nそのすべてが、被写体の“存在そのもの”を際立たせるためにある。\\n\\nコスプレ撮影では、キャラクターを再現するのではなく、\\n**「その世界に生きている人間の気配」**を写すことを目的とする。\\n日常のスナップでは、誰も気に留めない景色の中に潜む\\n小さな物語の断片を見つけ出し、静かに提示する。\\n\\n写真は、世界を“説明する”ためではなく、\\n世界の奥にある感情や余韻をそっと掬い上げるための行為。\\nDaitanはそう信じて、今日もシャッターを切り続けている。\\n\\n---\",\"location\":\"北海道　札幌　小樽近郊\",\"imageUrl\":\"https://res.cloudinary.com/ds4prfv5z/image/upload/v1771071950/pka8ayqeh8o7o4bl51ja.png\",\"locationEn\":\"Hokkaido, Sapporo\",\"roleEn\":\"Photographer\",\"bioEn\":\"Based in Hokkaido, Daitan is a photographer who captures the subtle presence that emerges between people and the world around them.\\n\\nWhether the subject is a character or a fragment of everyday life,\\nDaitan seeks to translate the temperature, breath, and quiet that flow through the moment into the form of a photograph.\\n\\nThere is little exaggeration or spectacle in Daitan’s work.\\nSoft light, muted tones, and generous space—\\neach element exists to reveal the subject’s very presence.\\n\\nIn cosplay photography, the goal is not to recreate a character,\\nbut to capture “the trace of a person living within that world.”\\nIn everyday snapshots, Daitan uncovers small, overlooked stories hidden in ordinary scenery and presents them with quiet clarity.\\n\\nPhotography, for Daitan, is not a tool to explain the world,\\nbut a way to gently scoop up the emotions and afterglow that lie beneath its surface.\\nWith that belief, Daitan continues to press the shutter.\\n\\n---\",\"mainGear\":[\"• Sony α7R V（ILCE‑7RM5）\",\"• SIGMA 24-70mm F2.8 DG DN II | Art（2nd Gen）\"],\"subGear\":[\"• Sony α7（ILCE‑7）\",\"• Sony α6400（ILCE‑6400）\",\"• FUJIFILM X-HF1（X-HALF）\",\"• Kodak FZ55\"],\"bioJa\":\"北海道を拠点に、人と世界のあいだに生まれる“かすかな気配”を写し取るフォトグラファー。\\n\\n被写体がキャラクターであれ、日常の断片であれ、 そこに流れる温度・呼吸・沈黙を丁寧に拾い上げ、 写真という形に変換することを探求している。\\n\\nDaitanの写真には、派手な演出や誇張はほとんどない。 光の柔らかさ、色の静けさ、余白の深さ。 そのすべてが、被写体の“存在そのもの”を際立たせるためにある。\\n\\nコスプレ撮影では、キャラクターを再現するのではなく、 **「その世界に生きている人間の気配」**を写すことを目的とする。 日常のスナップでは、誰も気に留めない景色の中に潜む 小さな物語の断片を見つけ出し、静かに提示する。\\n\\n写真は、世界を“説明する”ためではなく、 世界の奥にある感情や余韻をそっと掬い上げるための行為。 Daitanはそう信じて、今日もシャッターを切り続けている。\",\"xUrl\":\"https://x.com/photg_d3150no_1?s=21\",\"instagramUrl\":\"https://www.instagram.com/photog_daitan3150_no.1?igsh=MTBydXYwb2FjNjZhNA%3D%3D&utm_source=qr\",\"otherGear\":[\"Adapters｜アダプター\",\"\",\"• TECHART LM-EA9（AFアダプター）\",\"• TTArtisan M-E 6bit II\",\"\"],\"lenses\":[\"AF Lenses（Sony E-mount）\",\"\",\"• Sony FE 85mm F1.8\",\"• Sony FE 70-200mm F2.8 GM OSS II（SEL70200GM2）\",\"• Sony FE 55mm F1.8 ZA（Sonnar T*）\",\"• Sony FE 50mm F1.8\",\"• SIGMA 45mm F2.8 DG DN | Contemporary\",\"\",\"\",\"---\",\"\",\"Old Lenses（オールドレンズ / MF）\",\"\",\"• Minolta MC W.ROKKOR-HG 35mm F2.8\",\"• Minolta MC ROKKOR-PF 55mm F1.7\",\"• Konishiroku HEXANON 52mm F1.8\",\"• ASAHI PENTAX Super Takumar 50mm F1.4\",\"• SIGMA FISHEYE 16mm F2.8\",\"\",\"\",\"---\",\"\",\"Manual Lenses（現行MF）\",\"\",\"• TTArtisan 50mm F2.0\",\"voigtlander NOKTON classic 40mm F1.4 SC\",\"\",\"\",\"---\",\"\"],\"gear\":[\"Main System｜メイン機材\",\"\",\"• Sony α7R V（ILCE‑7RM5）\",\"• SIGMA 24-70mm F2.8 DG DN II | Art（2nd Gen）\",\"\",\"\",\"Sub System｜サブ機材\",\"\",\"• Sony α7（ILCE‑7）\",\"• Sony α6400（ILCE‑6400）\",\"• FUJIFILM X-HF1（X-HALF）\",\"• Kodak FZ55\",\"\",\"\",\"---\",\"\",\"Lenses｜レンズ\",\"\",\"AF Lenses（Sony E-mount）\",\"\",\"• Sony FE 85mm F1.8\",\"• Sony FE 70-200mm F2.8 GM OSS II（SEL70200GM2）\",\"• Sony FE 55mm F1.8 ZA（Sonnar T*）\",\"• Sony FE 50mm F1.8\",\"• SIGMA 45mm F2.8 DG DN | Contemporary\",\"\",\"\",\"Old Lenses（オールドレンズ / MF）\",\"\",\"• Minolta MC W.ROKKOR-HG 35mm F2.8\",\"• Minolta MC ROKKOR-PF 55mm F1.7\",\"• Konishiroku HEXANON 52mm F1.8\",\"• ASAHI PENTAX Super Takumar 50mm F1.4\",\"• SIGMA FISHEYE 16mm F2.8\",\"\",\"\",\"Manual Lenses（現行MF）\",\"\",\"• TTArtisan 50mm F2.0\",\"voigtlander NOKTON classic 40mm F1.4 SC\",\"\",\"\",\"---\",\"Adapters｜アダプター\",\"\",\"• TECHART LM-EA9（AFアダプター）\",\"• TTArtisan M-E 6bit II\",\"\",\"\",\"\",\"---\",\"\"],\"locationJa\":\"北海道　札幌,小樽近郊\",\"roleJa\":\"フォトグラファー\",\"updatedAt\":\"2026-02-20T11:04:13.715Z\"}}]\n","segmentData":{"/_tree":":HL[\"/_next/static/chunks/665dc3aa4aa2d85c.css\",\"style\"]\n:HL[\"/_next/static/chunks/ece9f4be9ae711ec.css\",\"style\"]\n:HL[\"/_next/static/chunks/d6d1e2ab9511bcef.css\",\"style\"]\n:HL[\"/_next/static/media/68d0ad77fd2c49e3-s.p.25e41569.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/media/83afe278b6a6bb3c-s.p.3a6ba036.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n0:{\"buildId\":\"wDtdeu55hWYsomNaN_VlH\",\"tree\":{\"name\":\"\",\"paramType\":null,\"paramKey\":\"\",\"hasRuntimePrefetch\":false,\"slots\":{\"children\":{\"name\":\"about\",\"paramType\":null,\"paramKey\":\"about\",\"hasRuntimePrefetch\":false,\"slots\":{\"children\":{\"name\":\"__PAGE__\",\"paramType\":null,\"paramKey\":\"__PAGE__\",\"hasRuntimePrefetch\":false,\"slots\":null,\"isRootLayout\":false}},\"isRootLayout\":false}},\"isRootLayout\":true},\"staleTime\":300}\n","/_full":"1:\"$Sreact.fragment\"\n2:I[62808,[\"/_next/static/chunks/d9fddd7e35bd589e.js\",\"/_next/static/chunks/152be74abaeef57d.js\",\"/_next/static/chunks/8d9ce281e2699520.js\",\"/_next/static/chunks/713069435030f2db.js\"],\"default\"]\n3:I[33750,[\"/_next/static/chunks/d9fddd7e35bd589e.js\",\"/_next/static/chunks/152be74abaeef57d.js\",\"/_next/static/chunks/8d9ce281e2699520.js\",\"/_next/static/chunks/713069435030f2db.js\"],\"LanguageProvider\"]\n4:I[31275,[\"/_next/static/chunks/d9fddd7e35bd589e.js\",\"/_next/static/chunks/152be74abaeef57d.js\",\"/_next/static/chunks/8d9ce281e2699520.js\",\"/_next/static/chunks/713069435030f2db.js\"],\"default\"]\n5:I[4152,[\"/_next/static/chunks/d9fddd7e