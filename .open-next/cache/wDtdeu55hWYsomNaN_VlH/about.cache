lucide lucide-search\" aria-hidden=\"true\"><path d=\"m21 21-4.34-4.34\"></path><circle cx=\"11\" cy=\"11\" r=\"8\"></circle></svg></button><button class=\"text-gray-900 hover:text-gray-600 transition-colors\" aria-label=\"Open Menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main class=\"min-h-screen pt-32 px-6 pb-24 bg-white selection:bg-black selection:text-white\"><div class=\"max-w-5xl mx-auto flex flex-col lg:flex-row gap-20 lg:gap-24 items-center lg:items-start\"><div class=\"w-full lg:w-[40%] lg:sticky lg:top-40\" style=\"opacity:0;transform:translateX(-30px)\"><div class=\"relative aspect-[3/4] w-full rounded-2xl overflow-hidden bg-gray-50\"><img alt=\"DAITAN\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-1000 hover:scale-105\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fres.cloudinary.com%2Fds4prfv5z%2Fimage%2Fupload%2Fv1771071950%2Fpka8ayqeh8o7o4bl51ja.png&amp;w=3840&amp;q=75\"/></div></div><div class=\"w-full lg:w-[60%] flex flex-col gap-14\" style=\"opacity:0;transform:translateY(20px)\"><header class=\"space-y-10\"><div class=\"space-y-2\"><span class=\"text-[10px] tracking-[0.8em] text-gray-400 uppercase block ml-1\" style=\"opacity:0;transform:translateX(-10px)\">Profile</span><h1 class=\"text-7xl md:text-9xl font-serif tracking-tighter text-gray-900 leading-none\" style=\"opacity:0\">ABOUT</h1></div><div class=\"space-y-8\"><h2 class=\"text-5xl md:text-7xl font-serif text-gray-900 tracking-tight\">DAITAN</h2><div class=\"flex flex-col gap-4\"><p class=\"text-gray-900 font-bold tracking-[0.5em] text-xs md:text-sm uppercase\">フォトグラファー</p><div class=\"flex items-center gap-3\"><div class=\"w-8 h-[1px] bg-gray-200\"></div><p class=\"text-gray-400 text-[10px] md:text-xs tracking-[0.3em] uppercase font-medium\">BASED IN <!-- -->北海道　札幌,小樽近郊</p></div></div></div></header><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 pt-4\"><div class=\"space-y-4\" style=\"opacity:0;transform:translateY(20px)\"><h3 class=\"text-[10px] font-bold tracking-[0.4em] uppercase text-gray-400\">Concept</h3><p class=\"text-gray-700 text-sm md:text-base leading-relaxed font-light\">「一瞬の光、一瞬の表情を、永遠の記憶に。」\n北海道・小樽を拠点に、ポートレートとスナップショットを中心に活動しています。単なる記録としての写真ではなく、その場の空気感や被写体の内面に潜む物語を、独自の視点で切り取ることを信条としています。</p></div><div class=\"space-y-4\" style=\"opacity:0;transform:translateY(20px)\"><h3 class=\"text-[10px] font-bold tracking-[0.4em] uppercase text-gray-400\">Vision</h3><p class=\"text-gray-700 text-sm md:text-base leading-relaxed font-light italic\">デジタル時代だからこそ、一枚の写真が持つ「重み」を大切にしたい。光と影の対比、そして人々の営みが織りなすドラマチックな瞬間を追い求め、見る人の心に「静かな感動」を届けることが私のミッションです。</p></div></div><section class=\"text-gray-800 text-lg md:text-xl font-normal leading-relaxed whitespace-pre-wrap max-w-2xl pt-8 relative\"><div class=\"absolute -left-6 top-8 w-1 h-12 bg-gray-100 hidden md:block\"></div><h3 class=\"text-[10px] font-bold tracking-[0.4em] uppercase text-gray-400 mb-6\">Biography</h3><div class=\"font-light\" style=\"line-height:2;letter-spacing:0.02em\">北海道を拠点に、人と世界のあいだに生まれる“かすかな気配”を写し取るフォトグラファー。\n\n被写体がキャラクターであれ、日常の断片であれ、 そこに流れる温度・呼吸・沈黙を丁寧に拾い上げ、 写真という形に変換することを探求している。\n\nDaitanの写真には、派手な演出や誇張はほとんどない。 光の柔らかさ、色の静けさ、余白の深さ。 そのすべてが、被写体の“存在そのもの”を際立たせるためにある。\n\nコスプレ撮影では、キャラクターを再現するのではなく、 **「その世界に生きている人間の気配」**を写すことを目的とする。 日常のスナップでは、誰も気に留めない景色の中に潜む 小さな物語の断片を見つけ出し、静かに提示する。\n\n写真は、世界を“説明する”ためではなく、 世界の奥にある感情や余韻をそっと掬い上げるための行為。 Daitanはそう信じて、今日もシャッターを切り続けている。</div></section><section class=\"pt-20 border-t border-gray-100\"><h2 class=\"text-[10px] font-bold tracking-[0.6em] mb-12 uppercase text-gray-400\" style=\"opacity:0\">Equipments</h2><div class=\"flex flex-col gap-12\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20\"><div class=\"space-y-10\"><div class=\"space-y-6\"><h3 class=\"text-xs font-bold tracking-[0.2em] text-gray-900 uppercase flex items-center gap-3\"><span class=\"w-1.5 h-1.5 bg-black rounded-full\"></span> Main Gear</h3><div class=\"space-y-4 pl-4 border-l border-gray-100\"><p class=\"text-gray-600 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Sony α7R V（ILCE‑7RM5）</p><p class=\"text-gray-600 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• SIGMA 24-70mm F2.8 DG DN II | Art（2nd Gen）</p></div></div><div class=\"space-y-6\"><h3 class=\"text-xs font-bold tracking-[0.2em] text-gray-400 uppercase flex items-center gap-3\"><span class=\"w-1.5 h-1.5 bg-gray-200 rounded-full\"></span> Sub Gear</h3><div class=\"space-y-4 pl-4 border-l border-gray-100\"><p class=\"text-gray-400 text-sm md:text-base leading-tight font-medium hover:text-gray-600 transition-colors italic\">• Sony α7（ILCE‑7）</p><p class=\"text-gray-400 text-sm md:text-base leading-tight font-medium hover:text-gray-600 transition-colors italic\">• Sony α6400（ILCE‑6400）</p><p class=\"text-gray-400 text-sm md:text-base leading-tight font-medium hover:text-gray-600 transition-colors italic\">• FUJIFILM X-HF1（X-HALF）</p><p class=\"text-gray-400 text-sm md:text-base leading-tight font-medium hover:text-gray-600 transition-colors italic\">• Kodak FZ55</p></div></div></div><div class=\"space-y-10\"><div class=\"space-y-6\"><h3 class=\"text-xs font-bold tracking-[0.2em] text-gray-900 uppercase flex items-center gap-3\"><span class=\"w-1.5 h-1.5 bg-gray-900 rounded-full scale-125\"></span> Lenses</h3><div class=\"grid grid-cols-1 gap-4 pl-4 border-l border-gray-100\"><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">AF Lenses（Sony E-mount）</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Sony FE 85mm F1.8</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Sony FE 70-200mm F2.8 GM OSS II（SEL70200GM2）</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Sony FE 55mm F1.8 ZA（Sonnar T*）</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Sony FE 50mm F1.8</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• SIGMA 45mm F2.8 DG DN | Contemporary</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">---</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">Old Lenses（オールドレンズ / MF）</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Minolta MC W.ROKKOR-HG 35mm F2.8</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Minolta MC ROKKOR-PF 55mm F1.7</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• Konishiroku HEXANON 52mm F1.8</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• ASAHI PENTAX Super Takumar 50mm F1.4</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• SIGMA FISHEYE 16mm F2.8</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">---</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">Manual Lenses（現行MF）</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• TTArtisan 50mm F2.0</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">voigtlander NOKTON classic 40mm F1.4 SC</p><p class=\"text-gray-700 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">---</p></div></div><div class=\"space-y-6\"><h3 class=\"text-xs font-bold tracking-[0.2em] text-gray-600 uppercase flex items-center gap-3\"><span class=\"w-1.5 h-1.5 bg-gray-400 rounded-full\"></span> Other</h3><div class=\"grid grid-cols-1 gap-4 pl-4 border-l border-gray-100\"><p class=\"text-gray-600 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">Adapters｜アダプター</p><p class=\"text-gray-600 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• TECHART LM-EA9（AFアダプター）</p><p class=\"text-gray-600 text-sm md:text-base leading-tight font-medium hover:text-black transition-colors\">• TTArtisan M-E 6bit II</p></div></div></div></div></div></section><footer class=\"pt-16 opacity-20\"><div class=\"h-px w-24 bg-gray-900\"></div></footer></div></div></main><!--$--><!--/$--><footer class=\"w-full py-12 px-6 flex flex-col items-center justify-center bg-white text-gray-500 text-sm font-sans tracking-widest border-t border-gray-100\"><div class=\"flex gap-8 mb-6\"><a href=\"https://instagram.com\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-3 rounded-full hover:bg-gray-50 hover:text-pink-600 transition-all duration-300 group\" aria-label=\"Instagram\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-instagram group-hover:scale-110 transition-transform\" aria-hidden=\"true\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg></a><a href=\"https://x.com\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-3 rounded-full hover:bg-gray-50 hover:text-blue-400 transition-all duration-300 group\" aria-label=\"Twitter\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-twitter group-hover:scale-110 transition-transform\" aria-hidden=\"true\"><path d=\"M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z\"></path></svg></a><a class=\"p-3 rounded-full hover:bg-gray-50 hover:text-gray-900 transition-all duration-300 group\" aria-l