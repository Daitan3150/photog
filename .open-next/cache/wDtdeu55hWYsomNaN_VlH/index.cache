ero.png 828w, /images/hero.png 1080w, /images/hero.png 1200w, /images/hero.png 1920w, /images/hero.png 2048w, /images/hero.png 3840w\" src=\"/images/hero.png\"/><div class=\"absolute inset-0 bg-black/30\"></div></div><div class=\"relative z-10 text-center text-white p-4 flex flex-col items-center\"><div class=\"w-32 h-32 md:w-56 md:h-56 mb-6 relative\" style=\"opacity:0;transform:scale(0.8)\"><img alt=\"DAITAN Logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain filter drop-shadow-2xl brightness-0 invert\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/logo.png 640w, /logo.png 750w, /logo.png 828w, /logo.png 1080w, /logo.png 1200w, /logo.png 1920w, /logo.png 2048w, /logo.png 3840w\" src=\"/logo.png\"/></div><h1 class=\"text-4xl md:text-8xl font-serif tracking-widest uppercase mb-4\" style=\"opacity:0;transform:translateY(20px)\">Daitan</h1><p class=\"text-sm md:text-base font-light tracking-[0.2em] font-sans uppercase mb-10 opacity-90\" style=\"opacity:0;transform:translateY(10px)\">Portrait &amp; Snapshot Photographer in Otaru</p><div class=\"flex flex-col sm:flex-row gap-4 sm:gap-6 mt-4 pointer-events-auto z-20\" style=\"opacity:0;transform:translateY(20px)\"><a href=\"/portfolio\" class=\"px-8 py-3 bg-white text-black text-sm tracking-widest uppercase font-bold hover:bg-black hover:text-white transition-all duration-300 border border-white rounded shadow-[0_0_15px_rgba(255,255,255,0.3)] hover:shadow-none min-w-[200px]\">ポートフォリオ</a><a href=\"/contact\" class=\"px-8 py-3 bg-transparent text-white text-sm tracking-widest uppercase font-bold hover:bg-white/10 transition-all duration-300 border border-white/50 hover:border-white rounded min-w-[200px]\">お問い合わせ</a></div></div><div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2\" style=\"opacity:0\"><span class=\"text-xs tracking-widest uppercase opacity-80\">スクロール</span><div class=\"w-[1px] h-20 bg-white/50 overflow-hidden\"><div class=\"w-full h-1/2 bg-white\"></div></div></div></section><section class=\"py-16 md:py-24 bg-neutral-50 px-4 md:px-12\"><div class=\"max-w-6xl mx-auto\"><div class=\"text-center mb-12 border-b border-black/10 pb-8\"><h2 class=\"text-2xl md:text-3xl font-serif mb-3 tracking-wide\">Featured Genres</h2><p class=\"text-gray-500 tracking-[0.2em] text-xs uppercase\">得意とする撮影ジャンル</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16\"><div class=\"group cursor-pointer\"><div class=\"overflow-hidden relative aspect-[4/5] bg-gray-200 mb-6\"><img alt=\"Portrait Photography\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcSet=\"/images/portrait.jpg 384w, /images/portrait.jpg 640w, /images/portrait.jpg 750w, /images/portrait.jpg 828w, /images/portrait.jpg 1080w, /images/portrait.jpg 1200w, /images/portrait.jpg 1920w, /images/portrait.jpg 2048w, /images/portrait.jpg 3840w\" src=\"/images/portrait.jpg\"/><div class=\"absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500\"></div></div><h3 class=\"text-2xl font-serif mb-2\">Portrait</h3><p class=\"text-gray-600 font-light leading-relaxed text-sm md:text-base\">被写体の持つ自然な表情や、その人らしさを引き出すポートレート撮影を得意としています。光と影を巧みに使い、物語を感じさせる一枚を切り取ります。</p></div><div class=\"group cursor-pointer md:mt-16\"><div class=\"overflow-hidden relative aspect-[4/5] bg-gray-200 mb-6\"><img alt=\"Snapshot Photography\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcSet=\"/images/snapshot.jpg 384w, /images/snapshot.jpg 640w, /images/snapshot.jpg 750w, /images/snapshot.jpg 828w, /images/snapshot.jpg 1080w, /images/snapshot.jpg 1200w, /images/snapshot.jpg 1920w, /images/snapshot.jpg 2048w, /images/snapshot.jpg 3840w\" src=\"/images/snapshot.jpg\"/><div class=\"absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500\"></div></div><h3 class=\"text-2xl font-serif mb-2\">Snapshot</h3><p class=\"text-gray-600 font-light leading-relaxed text-sm md:text-base\">日常の何気ない瞬間や、街の息遣いを切り取るスナップショット。小樽をはじめとした北海道の風景に溶け込む、ドラマチックな瞬間を追い求めています。</p></div></div></div></section><section class=\"py-16 md:py-24 px-4 md:px-12 bg-white\"><div class=\"text-center mb-10 md:mb-16\"><h2 class=\"text-3xl md:text-4xl font-serif mb-4\">Recent Works</h2><p class=\"text-gray-500 tracking-widest text-sm\">LATEST PHOTOGRAPHY</p></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><div class=\"text-center py-12\"><div class=\"w-8 h-8 border-2 border-gray-200 border-t-black rounded-full animate-spin mx-auto\"></div></div><!--/$--><div class=\"text-center mt-12\"><a href=\"/portfolio\" class=\"inline-block border-b border-black pb-1 hover:text-gray-600 transition-colors tracking-widest\">VIEW ALL WORKS</a></div></section></main><!--$--><!--/$--><footer class=\"w-full py-12 px-6 flex flex-col items-center justify-center bg-white text-gray-500 text-sm font-sans tracking-widest border-t border-gray-100\"><div class=\"flex gap-8 mb-6\"><a href=\"https://instagram.com\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"p-3 rounded-full hover:bg-gray-50 hover:text-pink-600 transition-all duration-300 group\" aria-label=\"Instagram\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-instagram group-hover:scale-110 transition-transform\" aria-hidden=\"true\"><re